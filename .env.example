# ── Server ──
PORT=8080

# Where RSVP emails are delivered
RSVP_TO_EMAIL=your-email@example.com

# SMTP (Nodemailer — MIT open source)
# Gmail: use an App Password → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── ntfy push notifications (Apache 2.0 open source) ──
# Free public server: https://ntfy.sh — or self-host your own ntfy instance
# 1. Install the ntfy app on your phone
# 2. Pick a unique topic name (e.g. himani-gender-reveal-2026)
# 3. Subscribe to that topic in the app
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your-unique-topic-name

# At least one of SMTP or NTFY must be configured for RSVPs to send.
